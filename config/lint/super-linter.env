CREATE_LOG_FILE=true
DEFAULT_BRANCH=main
ENABLE_GITHUB_PULL_REQUEST_SUMMARY_COMMENT=true
FILTER_REGEX_EXCLUDE=.*/gradlew|.*/mvnw
GITLEAKS_LOG_LEVEL=warn
IGNORE_GITIGNORED_FILES=true
JAVA_FILE_NAME=google_checks.xml
LINTER_RULES_PATH=config/lint
MARKDOWN_CONFIG_FILE=.markdown-lint.yaml
REMOVE_ANSI_COLOR_CODES_FROM_OUTPUT=true
SAVE_SUPER_LINTER_SUMMARY=true
SUPPRESS_POSSUM=true
VALIDATE_ALL_CODEBASE=true
VALIDATE_BIOME_FORMAT=false
VALIDATE_BIOME_LINT=false
VALIDATE_CHECKOV=false
VALIDATE_KUBERNETES_KUBECONFORM=false
VALIDATE_TRIVY=false
